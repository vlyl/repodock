{
  "name": "repodock",
  "displayName": "RepoDock",
  "version": "0.1.0",
  "description": "A persistent, configurable GitHub context dock that keeps your current repository context visible while you browse.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "RepoDock contributors",
  "homepage": "https://github.com/repodock/repodock",
  "repository": {
    "type": "git",
    "url": "https://github.com/repodock/repodock.git"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "postinstall": "wxt prepare",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:chrome": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "build:all": "wxt build -b chrome && wxt build -b firefox && wxt build -b edge",
    "zip": "wxt zip",
    "zip:chrome": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "zip:all": "wxt zip -b chrome && wxt zip -b firefox && wxt zip -b edge",
    "submit:init": "wxt submit init",
    "submit:dry": "wxt submit --dry-run --chrome-zip .output/*-chrome.zip --firefox-zip .output/*-firefox.zip --firefox-sources-zip .output/*-sources.zip --edge-zip .output/*-edge.zip",
    "submit": "wxt submit --chrome-zip .output/*-chrome.zip --firefox-zip .output/*-firefox.zip --firefox-sources-zip .output/*-sources.zip --edge-zip .output/*-edge.zip",
    "typecheck": "wxt prepare && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "icons": "node scripts/generate-icons.mjs",
    "e2e": "wxt build -b chrome && playwright test",
    "e2e:only": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "prepare:playwright": "playwright install chromium"
  },
  "dependencies": {
    "@primer/octicons-react": "^19.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@wxt-dev/module-react": "^1.2.2",
    "axe-core": "^4.12.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^7.3.5",
    "vitest": "^4.1.9",
    "wxt": "^0.20.26"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.3.5",
      "@vitejs/plugin-react": "^4.7.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "workerd"
    ]
  }
}
