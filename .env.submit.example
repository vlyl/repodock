# Store submission credentials for `pnpm submit` (wxt submit / publish-extension).
# Copy to `.env.submit` (gitignored) and fill in, or set these as CI secrets.
# Run `pnpm submit:init` for an interactive walkthrough.

# --- Chrome Web Store ---
CHROME_EXTENSION_ID=
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=
# CHROME_PUBLISH_TARGET=default            # or "trustedTesters"
# CHROME_SKIP_SUBMIT_REVIEW=false          # upload only, don't submit for review

# --- Firefox Add-ons (AMO) ---
FIREFOX_EXTENSION_ID=repodock@repodock.dev
FIREFOX_JWT_ISSUER=
FIREFOX_JWT_SECRET=
# FIREFOX_CHANNEL=listed                   # or "unlisted"

# --- Microsoft Edge Add-ons ---
EDGE_PRODUCT_ID=
EDGE_CLIENT_ID=
EDGE_API_KEY=
# EDGE_SKIP_SUBMIT_REVIEW=false
