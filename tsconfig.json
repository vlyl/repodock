{
  // The base config is generated by `wxt prepare` and wires up the `@/*`
  // path alias, the `#imports` virtual module, JSX, and the WXT global types.
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    // React 19 automatic JSX runtime (WXT's React module wires the bundler, but
    // not `tsc`, so we set it here for type-checking).
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    // Full strict mode, plus the high-value additional safety checks.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "allowUnreachableCode": false,
    // Module hygiene: require explicit `import type` and keep emit predictable.
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    // Type-checking ergonomics.
    "skipLibCheck": true
  },
  "exclude": ["node_modules", ".output", "coverage", "playwright-report", "test-results"]
}
